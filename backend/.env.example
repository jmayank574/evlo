# Voltpath backend configuration. Copy to .env and fill in. NEVER commit .env.

# --- Database ---
# Local dev (Docker): postgresql+psycopg://voltpath:voltpath@localhost:5432/voltpath
# Railway provides DATABASE_URL automatically in production.
DATABASE_URL=postgresql+psycopg://voltpath:voltpath@localhost:5432/voltpath

# --- External APIs (real data — provisioned by operator) ---
# NREL Alternative Fuels Data Center: https://developer.nrel.gov/
NREL_API_KEY=
# Open Charge Map: https://openchargemap.org/site/develop/api
OPENCHARGEMAP_API_KEY=
# Mapbox Directions — SECRET, server-side only:
MAPBOX_TOKEN=
# Mapbox public token (pk.*) — frontend map display only, safe to expose:
MAPBOX_PUBLIC_TOKEN=

# --- Cache TTLs (seconds) ---
# How long cached charger results stay fresh before refresh.
CHARGER_CACHE_TTL_SECONDS=86400
# How long cached routing results stay fresh.
ROUTE_CACHE_TTL_SECONDS=604800
